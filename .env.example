# Environment Variables for Business Analyzer

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=your-very-secure-random-secret-key-here

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Database Configuration (optional - defaults to local files)
# USER_DB_PATH=/app/data/USER.db
# BUSINESS_DB_PATH=/app/data/BUSINESS.db

# Email Configuration (optional)
# SMTP_HOST=localhost
# SMTP_PORT=25
# SMTP_USER=
# SMTP_PASSWORD=
